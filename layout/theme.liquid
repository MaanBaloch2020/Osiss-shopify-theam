<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {%- if page_title -%}
    [span_0](start_span)<title>{{ page_title }} — OSISS™</title>[span_0](end_span)
  {%- else -%}
    [span_1](start_span)<title>{{ shop.name }} — Innovative Dermatology-Driven Skincare</title>[span_1](end_span)
  {%- endif -%}

  {%- if page_description -%}
    [span_2](start_span)<meta name="description" content="{{ page_description | escape }}">[span_2](end_span)
  {%- else -%}
    [span_3](start_span)<meta name="description" content="OSISS™ — Science-backed skincare powered by dermatology. PCSIR Tested, DRAP Compliant, GMP Certified. Proudly made in Pakistan.">[span_3](end_span)
  {%- endif -%}

  [span_4](start_span)<meta property="og:site_name" content="{{ shop.name }}">[span_4](end_span)
  [span_5](start_span)<meta property="og:url" content="{{ canonical_url }}">[span_5](end_span)
  [span_6](start_span)<meta property="og:title" content="{{ page_title | default: shop.name }}">[span_6](end_span)
  [span_7](start_span)<meta property="og:type" content="website">[span_7](end_span)
  {%- if page_image -%}
    [span_8](start_span)<meta property="og:image" content="{{ page_image | img_url: 'master' }}">[span_8](end_span)
  {%- endif -%}
  [span_9](start_span)<meta property="og:description" content="{{ page_description | default: shop.description | escape }}">[span_9](end_span)

  [span_10](start_span)<meta name="twitter:card" content="summary_large_image">[span_10](end_span)
  [span_11](start_span)<meta name="twitter:title" content="{{ page_title | default: shop.name }}">[span_11](end_span)
  [span_12](start_span)<meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">[span_12](end_span)

  [span_13](start_span)<link rel="canonical" href="{{ canonical_url }}">[span_13](end_span)

  [span_14](start_span)<link rel="preconnect" href="https://fonts.googleapis.com">[span_14](end_span)
  [span_15](start_span)<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>[span_15](end_span)
  [span_16](start_span)<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">[span_16](end_span)

  [span_17](start_span){{ 'theme.css' | asset_url | stylesheet_tag }}[span_17](end_span)

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Osiss",
    "alternateName": "OSISS™",
    "url": "{{ shop.url }}",
    [span_18](start_span)"logo": "{{ 'osiss-logo.png' | asset_url }}",[span_18](end_span)
    [span_19](start_span)"description": "OSISS™ is a dermatology-driven skincare brand from Pakistan. PCSIR Tested, DRAP Compliant, GMP Certified and Cruelty-Free.",[span_19](end_span)
    "foundingLocation": {
      "@type": "Place",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lahore",
        "addressCountry": "PK"
      }
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+923021345111",
      "contactType": "customer service",
      [span_20](start_span)"availableLanguage": ["English", "Urdu"][span_20](end_span)
    },
    "sameAs": [
      "https://www.instagram.com/osiss.pk"
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "OSISS™",
    "url": "{{ shop.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
      },
      [span_21](start_span)"query-input": "required name=search_term_string"[span_21](end_span)
    }
  }
  </script>

  [span_22](start_span){{ content_for_header }}[span_22](end_span)
</head>

<body class="template-{{ template.name }}">

  [span_23](start_span){%- sections 'header' -%}[span_23](end_span)

  <main id="main-content" role="main">
    [span_24](start_span){{ content_for_layout }}[span_24](end_span)
  </main>

  [span_25](start_span){%- sections 'footer' -%}[span_25](end_span)

  [span_26](start_span){%- render 'cart-panel' -%}[span_26](end_span)
  [span_27](start_span){%- render 'wishlist-panel' -%}[span_27](end_span)
  [span_28](start_span){%- render 'quick-view' -%}[span_28](end_span)

  [span_29](start_span)<a href="https://wa.me/{{ settings.whatsapp_number | default: '923021345111' }}"[span_29](end_span)
     target="_blank"
     rel="noopener noreferrer"
     class="wa-float"
     aria-label="Chat on WhatsApp">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
      [span_30](start_span)<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>[span_30](end_span)
      [span_31](start_span)<path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.557 4.115 1.529 5.844L.057 23.927l6.235-1.634A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.787 9.787 0 01-5.34-1.576l-.383-.227-3.7.97.988-3.608-.249-.396A9.788 9.788 0 012.182 12C2.182 6.567 6.567 2.182 12 2.182 17.433 2.182 21.818 6.567 21.818 12S17.433 21.818 12 21.818z"/>[span_31](end_span)
    </svg>
    <span>Expert Advice</span>
  </a>

  [span_32](start_span)<script src="{{ 'theme.js' | asset_url }}" defer></script>[span_32](end_span)
</body>
</html>
