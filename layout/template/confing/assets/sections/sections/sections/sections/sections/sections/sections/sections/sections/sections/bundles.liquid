<section class="bundles-sec" aria-labelledby="bundles-title">
  <div class="wrap">

    <p class="sec-eyebrow">{{ section.settings.eyebrow | default: 'SAVE MORE TOGETHER' }}</p>
    <h2 class="sec-ttl" id="bundles-title">{{ section.settings.title | default: 'CURATED BUNDLES' }}</h2>
    <div class="sec-rule" aria-hidden="true"></div>

    {%- if section.settings.show_tier_bar -%}
    <div class="bundle-tier-bar">
      <div class="bundle-tier-item">
        <span class="bti-qty">2 items</span>
        <span class="bti-disc">{{ section.settings.tier_2 | default: '5% OFF' }}</span>
      </div>
      <div class="bundle-tier-divider">→</div>
      <div class="bundle-tier-item highlight">
        <span class="bti-qty">3+ items</span>
        <span class="bti-disc">{{ section.settings.tier_3 | default: '15% OFF' }}</span>
      </div>
    </div>
    {%- endif -%}

    <div class="bundles-grid">
      {%- for block in section.blocks -%}
        <div class="bundle-card" {{ block.shopify_attributes }}>
          <div class="bundle-badge">{{ block.settings.badge | default: 'BEST VALUE' }}</div>
          
          <div class="bundle-img-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}" alt="{{ block.settings.bundle_name }}" loading="lazy">
            {%- else -%}
              <div class="placeholder-img">Bundle Image</div>
            {%- endif -%}
            
            <div class="bundle-save-tag">{{ block.settings.save_label }}</div>
          </div>

          <div class="bundle-details">
            <h3 class="bundle-card-ttl">{{ block.settings.bundle_name }}</h3>
            <p class="bundle-tagline">{{ block.settings.tagline }}</p>
            
            <ul class="bundle-includes">
              <li>{{ block.settings.product_1_name }}</li>
              <li>{{ block.settings.product_2_name }}</li>
              {%- if block.settings.product_3_name != blank -%}
                <li>{{ block.settings.product_3_name }}</li>
              {%- endif -%}
            </ul>

            <div class="bundle-price-area">
              <span class="price-old">Rs. {{ block.settings.original_price }}</span>
              <span class="price-new">Rs. {{ block.settings.sale_price }}</span>
            </div>

            <button class="btn primary full-width bundle-atc">Add Bundle to Cart</button>
            <p class="bundle-viewers">🔥 {{ block.settings.viewers }} people are looking at this set</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Bundles",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SAVE MORE TOGETHER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "CURATED BUNDLES"
    },
    {
      "type": "checkbox",
      "id": "show_tier_bar",
      "label": "Show Discount Tiers",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "bundle_card",
      "name": "Bundle Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "BEST VALUE"
        },
        {
          "type": "text",
          "id": "bundle_name",
          "label": "Bundle Name",
          "default": "The Glow Starter Kit"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Cleanse · Treat · Protect"
        },
        {
          "type": "text",
          "id": "product_1_name",
          "label": "Product 1",
          "default": "Gentle Foaming Cleanser"
        },
        {
          "type": "text",
          "id": "product_2_name",
          "label": "Product 2",
          "default": "Revitalizing Face Serum"
        },
        {
          "type": "text",
          "id": "product_3_name",
          "label": "Product 3",
          "default": "Optimal Sunscreen Stick"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price (Numbers only)",
          "default": "5849"
        },
        {
          "type": "text",
          "id": "sale_price",
          "label": "Sale Price (Numbers only)",
          "default": "4199"
        },
        {
          "type": "text",
          "id": "save_label",
          "label": "Save Label",
          "default": "Save PKR 1,650"
        },
        {
          "type": "number",
          "id": "viewers",
          "label": "Fake Viewers Count",
          "default": 11
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Bundles",
      "blocks": [
        { "type": "bundle_card" },
        { "type": "bundle_card" }
      ]
    }
  ]
}
{% endschema %}
