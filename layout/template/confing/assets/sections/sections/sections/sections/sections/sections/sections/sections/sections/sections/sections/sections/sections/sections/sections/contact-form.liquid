<section class="contact-sec" aria-labelledby="contact-title">
  <div class="wrap">
    
    <p class="sec-eyebrow">{{ section.settings.eyebrow | default: 'GET IN TOUCH' }}</p>
    <h2 class="sec-ttl" id="contact-title">{{ section.settings.title | default: 'WE ARE HERE TO HELP' }}</h2>
    <div class="sec-rule" aria-hidden="true"></div>

    <div class="contact-grid">
      
      <div class="contact-info">
        <h3 class="contact-sub-ttl">Customer Support</h3>
        <p class="contact-text">Have a question about our products or your order? Reach out to us and our skincare experts will assist you.</p>
        
        <div class="contact-list">
          <div class="contact-item">
            <strong>Email:</strong> <span>{{ section.settings.email | default: 'support@osiss.pk' }}</span>
          </div>
          <div class="contact-item">
            <strong>WhatsApp:</strong> <span>{{ section.settings.whatsapp | default: '+92 300 1234567' }}</span>
          </div>
          <div class="contact-item">
            <strong>Hours:</strong> <span>Mon - Sat: 10AM - 6PM</span>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap">
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p class="form-success">✓ Message sent! We will get back to you shortly.</p>
          {%- elsif form.errors -%}
            <p class="form-error">! Please check your information and try again.</p>
          {%- endif -%}

          <div class="form-row">
            <input type="text" name="contact[name]" placeholder="Full Name" required>
            <input type="email" name="contact[email]" placeholder="Email Address" required>
          </div>
          
          <input type="tel" name="contact[phone]" placeholder="Phone Number (Optional)">
          <textarea name="contact[body]" rows="5" placeholder="Your Message" required></textarea>

          <button type="submit" class="btn primary full-width">Send Message</button>
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

<style>
  .contact-sec { padding: 80px 0; background: #fff; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 60px; margin-top: 40px; }
  .contact-sub-ttl { font-size: 1.5rem; margin-bottom: 15px; font-weight: 700; color: #1a1a1a; }
  .contact-text { color: #666; margin-bottom: 30px; line-height: 1.6; }
  .contact-item { margin-bottom: 15px; font-size: 1rem; }
  .contact-item strong { color: #1a1a1a; width: 100px; display: inline-block; }
  
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px; }
  .contact-form-wrap input, .contact-form-wrap textarea { 
    width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; 
    font-family: inherit; margin-bottom: 15px; 
  }
  .form-success { background: #e7f3ef; color: #2d6a4f; padding: 15px; border-radius: 4px; margin-bottom: 20px; }
  .form-error { background: #fbeaea; color: #c0392b; padding: 15px; border-radius: 4px; margin-bottom: 20px; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "GET IN TOUCH"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "WE ARE HERE TO HELP"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Support Email",
      "default": "support@osiss.pk"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp Number",
      "default": "+92 300 1234567"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
