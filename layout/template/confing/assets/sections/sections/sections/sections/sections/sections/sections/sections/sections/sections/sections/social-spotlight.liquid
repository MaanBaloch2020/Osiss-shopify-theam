<section class="social-sec" aria-labelledby="social-title">

  <div class="wrap" style="padding-bottom:0">
    <p class="sec-eyebrow">{{ section.settings.handle_text | default: '@OSISS.PK' }}</p>
    <h2 class="sec-ttl" id="social-title">{{ section.settings.title | default: 'SOCIAL SPOTLIGHT' }}</h2>
  </div>

  <div class="reels-row" id="reelsRow" role="list" aria-label="Social media posts">

    {%- for block in section.blocks -%}
      {%- if block.type == 'reel_card' -%}
      <div class="reel-card" role="listitem" {{ block.shopify_attributes }}>

        {%- if block.settings.post_link != blank -%}
          <a href="{{ block.settings.post_link }}" target="_blank" rel="noopener noreferrer" class="reel-inner" aria-label="{{ block.settings.label | default: 'View on Instagram' }}">
        {%- else -%}
          <div class="reel-inner">
        {%- endif -%}

          {%- if block.settings.post_image != blank -%}
            <img
              src="{{ block.settings.post_image | img_url: '320x568', crop: 'center' }}"
              alt="{{ block.settings.label | default: 'OSISS social post' }}"
              loading="lazy"
              class="reel-bg-img"
            >
          {%- else -%}
            <div class="reel-placeholder" style="background: linear-gradient(135deg, {{ block.settings.gradient_from }}, {{ block.settings.gradient_to }})"></div>
          {%- endif -%}

          <div class="reel-content">
            {%- if block.settings.show_play_icon -%}
              <div class="reel-play" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            {%- endif -%}
            
            <div class="reel-bottom">
              <span class="reel-tag">{{ block.settings.product_tag }}</span>
              <p class="reel-label">{{ block.settings.label }}</p>
            </div>
          </div>

        {%- if block.settings.post_link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <div class="wrap" style="padding-top:20px; text-align:center;">
    <a href="{{ section.settings.social_url | default: '#' }}" class="btn secondary" target="_blank">FOLLOW OUR JOURNEY</a>
  </div>

</section>

{% schema %}
{
  "name": "Social Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "handle_text",
      "label": "Social Handle",
      "default": "@OSISS.PK"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SOCIAL SPOTLIGHT"
    },
    {
      "type": "url",
      "id": "social_url",
      "label": "Social Media Profile Link"
    }
  ],
  "blocks": [
    {
      "type": "reel_card",
      "name": "Social Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "post_image",
          "label": "Post/Reel Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Short Caption",
          "default": "Morning Routine ✨"
        },
        {
          "type": "text",
          "id": "product_tag",
          "label": "Product Tag",
          "default": "SUN STICK SPF 50+"
        },
        {
          "type": "url",
          "id": "post_link",
          "label": "Link to post"
        },
        {
          "type": "checkbox",
          "id": "show_play_icon",
          "label": "Show play icon",
          "default": true
        },
        {
          "type": "color",
          "id": "gradient_from",
          "label": "Fallback Gradient Start",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "gradient_to",
          "label": "Fallback Gradient End",
          "default": "#2a2a2a"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Spotlight",
      "blocks": [
        { "type": "reel_card", "settings": { "label": "Morning Skincare Routine ✨", "product_tag": "FOAMING CLEANSER" } },
        { "type": "reel_card", "settings": { "label": "SPF — Your Daily Must ☀️", "product_tag": "SUN STICK SPF 50+" } },
        { "type": "reel_card", "settings": { "label": "Glow Up with Hyaluronic 💧", "product_tag": "FACE SERUM" } }
      ]
    }
  ]
}
{% endschema %}
