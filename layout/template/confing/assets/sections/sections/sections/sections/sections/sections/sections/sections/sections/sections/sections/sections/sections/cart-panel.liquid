{% comment %}
  Snippet: cart-panel.liquid
  Renders the off-canvas AJAX cart panel.
  Content is populated by theme.js -> updateShopifyCartUI() and renderCart().
{% endcomment %}

<div
  class="cart-overlay"
  id="cartOverlay"
  aria-hidden="true"
  role="presentation"
></div>

<aside
  class="cart-panel"
  id="cartPanel"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true"
>

  <div class="cart-hdr">
    <div class="cart-ttl">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      YOUR CART
    </div>
    <button
      class="ib"
      id="cartCloseBtn"
      aria-label="Close cart"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-body" id="cartBody" aria-live="polite">
    <div class="cart-empty-state" id="cartEmptyState">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#eee" stroke-width="1.5" class="cart-empty-icon" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <p class="cart-empty-txt">Your cart is empty</p>
      <p class="cart-empty-sub">Add some products to get started</p>
    </div>
    
    <div id="cartItemsList" class="cart-items-list">
      </div>
  </div>

  <div class="cart-foot" id="cartFoot" style="display:none" aria-label="Cart totals">
    <div class="cart-totals">
      <div class="ctr">
        <span class="ctr-l">SUBTOTAL</span>
        <span class="ctr-v" id="cartSubtotal">PKR 0</span>
      </div>
      <div class="ctr">
        <span class="ctr-l">SHIPPING</span>
        <span class="ctr-v" id="cartShipping">PKR 250</span>
      </div>
      <div class="ctr cart-grand">
        <span class="ctr-l">TOTAL</span>
        <span class="ctr-v" id="cartTotal">PKR 250</span>
      </div>
    </div>

    <a href="/checkout" class="btn primary full-width checkout-btn" id="checkoutBtn">
      CHECKOUT NOW
    </a>
  </div>

</aside>

{% schema %}
{
  "name": "Cart Panel",
  "settings": [],
  "presets": [
    {
      "name": "Cart Panel"
    }
  ]
}
{% endschema %}
