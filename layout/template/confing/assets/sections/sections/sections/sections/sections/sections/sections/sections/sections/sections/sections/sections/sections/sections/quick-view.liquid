{% comment %}
  Snippet: quick-view.liquid
  Quick View modal overlay ko render karta hai.
  Iska content theme.js ke openQuickView function se populate hota hai.
{% endcomment %}

<div
  class="qv-ov"
  id="qvOverlay"
  role="dialog"
  aria-modal="true"
  aria-label="Quick view"
  aria-hidden="true"
>
  <div class="qv-box" id="qvBox" role="document">

    <button
      class="qv-close"
      id="qvClose"
      aria-label="Close quick view"
      onclick="closeQuickView()"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="qv-loading" id="qvLoading" aria-live="polite">
      <div class="qv-spinner"></div>
      <p>Loading product…</p>
    </div>

    <div class="qv-content" id="qvContent" style="display:none">
      <div class="qv-grid">
        
        <div class="qv-media">
          <div id="qvImages" class="qv-images-track">
            </div>
        </div>

        <div class="qv-details">
          <p class="qv-vendor" id="qvVendor"></p>
          <h2 class="qv-title" id="qvTitle"></h2>
          
          <div class="qv-price-row">
            <span class="qv-price-compare" id="qvComparePrice"></span>
            <span class="qv-price-current" id="qvPrice"></span>
          </div>

          <div class="qv-desc" id="qvDesc"></div>

          <div class="qv-variants" id="qvVariants"></div>

          <div class="qv-actions">
            <div class="qty-ctrl">
              <button class="qbtn" id="qvQtyMinus" aria-label="Decrease quantity">−</button>
              <span class="qnum" id="qvQtyNum">1</span>
              <button class="qbtn" id="qvQtyPlus" aria-label="Increase quantity">+</button>
            </div>

            <button class="btn primary full-width" id="qvAtcBtn">
              ADD TO CART
            </button>
          </div>

          <a href="#" id="qvViewFull" class="qv-view-link">View full details →</a>
        </div>

      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Quick View",
  "settings": [],
  "presets": [
    {
      "name": "Quick View"
    }
  ]
}
{% endschema %}
