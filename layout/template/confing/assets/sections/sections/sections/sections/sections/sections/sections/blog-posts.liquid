{%- liquid
  assign blog_handle = section.settings.blog | default: 'skin-care-insights'
  assign posts_to_show = section.settings.posts_to_show | default: 4
  assign featured_blog = blogs[blog_handle]
-%}

<section class="blog-sec" aria-labelledby="blog-title">
  <div class="wrap">

    <p class="sec-eyebrow">{{ section.settings.eyebrow | default: 'FROM THE LAB' }}</p>
    <h2 class="sec-ttl" id="blog-title">{{ section.settings.title | default: 'SKIN CARE INSIGHTS' }}</h2>
    <div class="sec-rule" aria-hidden="true"></div>

    <div class="sl-wrap" id="blogWrap" role="region" aria-label="Blog posts">
      <button class="sl-arrow prev" id="blogPrev" aria-label="Previous blog posts">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="sl-track" id="blogTrack" role="list">

        {%- if featured_blog != blank and featured_blog.articles_count > 0 -%}
          {%- for article in featured_blog.articles limit: posts_to_show -%}
            <article class="blog-card" role="listitem">
              <div class="blog-img-box">
                {%- if article.image -%}
                  <img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.title }}" loading="lazy">
                {%- else -%}
                  <div class="placeholder-img"></div>
                {%- endif -%}
                <span class="blog-tag">{{ article.tags[0] | default: 'Skincare' }}</span>
              </div>
              <div class="blog-info">
                <h3 class="blog-card-ttl">{{ article.title }}</h3>
                <p class="blog-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 15 }}</p>
                <a href="{{ article.url }}" class="blog-link">Read Full Article →</a>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            <article class="blog-card" role="listitem" {{ block.shopify_attributes }}>
              <div class="blog-img-box">
                <div class="placeholder-img" style="background:#eee; height:220px;"></div>
                <span class="blog-tag">{{ block.settings.tag }}</span>
              </div>
              <div class="blog-info">
                <p class="blog-meta">{{ block.settings.date }} • {{ block.settings.read_time }} min read</p>
                <h3 class="blog-card-ttl">{{ block.settings.title }}</h3>
                <p class="blog-excerpt">{{ block.settings.excerpt }}</p>
                <span class="blog-link">Read Full Article →</span>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}

      </div>

      <button class="sl-arrow next" id="blogNext" aria-label="Next blog posts">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <div class="sec-btn-row">
      <a href="{{ featured_blog.url | default: '/blogs/news' }}" class="btn secondary">View All Insights</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "FROM THE LAB"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SKIN CARE INSIGHTS"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Number of posts to show",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "blog_post",
      "name": "Manual Blog Post",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Post Title",
          "default": "How to achieve the perfect Osiss Glow"
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "Excerpt",
          "default": "Discover the step-by-step routine used by dermatologists for healthier skin."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Category Tag",
          "default": "SKIN CARE"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date Display",
          "default": "April 2025"
        },
        {
          "type": "number",
          "id": "read_time",
          "label": "Read Time (mins)",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Posts",
      "blocks": [
        {
          "type": "blog_post",
          "settings": {
            "title": "The Importance of SPF 50+ in Your Daily Routine",
            "excerpt": "Dermatologists agree: daily sun protection is the single most effective anti-aging step you can build into your routine.",
            "tag": "SUN CARE",
            "date": "March 2025",
            "read_time": 3
          }
        },
        {
          "type": "blog_post",
          "settings": {
            "title": "Hyaluronic Acid: The Science of Deep Hydration",
            "excerpt": "Learn how Hyaluronic Acid holds up to 1000x its weight in water and why it belongs in every skincare routine.",
            "tag": "INGREDIENTS",
            "date": "February 2025",
            "read_time": 4
          }
        },
        {
          "type": "blog_post",
          "settings": {
            "title": "Building a Skincare Routine for Pakistani Climate",
            "excerpt": "Hot, humid summers and dry winters require a skincare strategy designed specifically for Pakistan's unique climate zones.",
            "tag": "ROUTINES",
            "date": "January 2025",
            "read_time": 5
          }
        },
        {
          "type": "blog_post",
          "settings": {
            "title": "What DRAP Certification Really Means for Your Skincare",
            "excerpt": "Understanding Pakistan's Drug Regulatory Authority certification and why it matters for the products you put on your skin.",
            "tag": "SCIENCE",
            "date": "December 2024",
            "read_time": 4
          }
        }
      ]
    }
  ]
}
{% endschema %}
