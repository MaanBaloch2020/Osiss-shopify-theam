  "name": "Header",
  "tag": "div",
  "class": "site-header-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Sale Strip"
    },
    {
      "type": "checkbox",
      "id": "show_sale_strip",
      "label": "Show sale countdown strip",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_text",
      "label": "Sale label",
      "default": "FLASH SALE"
    },
    {
      "type": "text",
      "id": "sale_offer",
      "label": "Offer prefix",
      "default": "Up to"
    },
    {
      "type": "text",
      "id": "sale_discount",
      "label": "Discount amount",
      "default": "25% OFF"
    },
    {
      "type": "text",
      "id": "sale_btn_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "sale_btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Ticker"
