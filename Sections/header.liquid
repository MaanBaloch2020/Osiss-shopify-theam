      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "nav_link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "nav_link_2",
      "label": "Link 2 label",
      "default": "Face"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "nav_link_3",
      "label": "Link 3 label",
      "default": "Sun Care"
    },
    {
      "type": "url",
      "id": "nav_link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "nav_link_4",
      "label": "Link 4 label",
      "default": "Hair"
    },
    {
      "type": "url",
      "id": "nav_link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "nav_link_5",
      "label": "Link 5 label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "nav_link_5_url",
