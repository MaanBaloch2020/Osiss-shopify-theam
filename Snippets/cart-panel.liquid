{% comment %}
  Snippet: cart-panel.liquid
  Renders the off-canvas AJAX cart panel.
  Content is populated by theme.js → updateShopifyCartUI() and renderCart().
  Place once in theme.liquid.
{% endcomment %}

<!-- Cart overlay -->
<div
  class="cart-overlay"
  id="cartOverlay"
  aria-hidden="true"
  role="presentation"
></div>

<!-- Cart panel -->
<aside
  class="cart-panel"
  id="cartPanel"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true"
>

  <!-- Header -->
  <div class="cart-hdr">
    <div class="cart-ttl">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      YOUR CART
    </div>
    <button
      class="ib"
      id="cartCloseBtn"
      aria-label="Close cart"
      onclick="closeCart()"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Shipping progress bar -->
  <div class="ship-prog" id="shipProg" aria-live="polite" style="display:none">
    <p class="prog-msg" id="progMsg"></p>
    <div class="prog-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
      <div class="prog-fill" id="progFill" style="width:0%"></div>
    </div>
  </div>

  <!-- Cart items -->
  <div
    class="cart-body"
    id="cartBody"
    aria-live="polite"
    aria-label="Cart items"
  >
    <!-- Populated by theme.js -->
    <div class="cart-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="1.5" class="cart-empty-icon" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <p class="cart-empty-txt">Your cart is empty</p>
      <p class="cart-empty-sub">Add some products to get started</p>
    </div>
  </div>

  <!-- Cart footer: totals + checkout -->
  <div class="cart-foot" id="cartFoot" style="display:none" aria-label="Cart totals">
    <div class="cart-totals">
      <div class="ctr">
        <span class="ctr-l">SUBTOTAL</span>
        <span class="ctr-v" id="cartSubtotal">PKR 0</span>
      </div>
      <div class="ctr">
        <span class="ctr-l">SHIPPING</span>
        <span class="ctr-v" id="cartShipping">PKR 250</span>
      </div>
      <div class="ctr cart-grand">
        <span class="ctr-l">TOTAL</span>
        <span class="ctr-v" id="cartTotal">PKR 250</span>
      </div>
    </div>

    <!-- Checkout -->
    <a href="/checkout" class="btn-checkout" id="checkoutBtn" role="button">
      PROCEED TO CHECKOUT
    </a>
    <button
      class="btn-continue"
      id="cartContinueBtn"
      onclick="closeCart()"
      aria-label="Continue shopping"
    >
      CONTINUE SHOPPING
    </button>

    <!-- Trust micro-bar -->
    <div class="cart-trust">
      <span>🔒 Secure Checkout</span>
      <span>·</span>
      <span>📦 Fast Delivery</span>
      <span>·</span>
      <span>↩ Easy Returns</span>
    </div>
  </div>

</aside>
