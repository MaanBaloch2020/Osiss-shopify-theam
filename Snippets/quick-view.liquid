{% comment %}
  Snippet: quick-view.liquid
  Renders the Quick View modal overlay.
  The modal content is populated by theme.js → openQuickView(productHandle)
  Place once in theme.liquid or the homepage template.
{% endcomment %}

<!-- ══ QUICK VIEW MODAL ══ -->
<div
  class="qv-ov"
  id="qvOverlay"
  role="dialog"
  aria-modal="true"
  aria-label="Quick view"
  aria-hidden="true"
>
  <div class="qv-box" id="qvBox" role="document">

    <button
      class="qv-close"
      id="qvClose"
      aria-label="Close quick view"
      onclick="closeQuickView()"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Loading state -->
    <div class="qv-loading" id="qvLoading" aria-live="polite">
      <div class="qv-spinner"></div>
      <p>Loading product…</p>
    </div>

    <!-- Product content (populated by JS) -->
    <div class="qv-content" id="qvContent" style="display:none">

      <div class="qv-grid">

        <!-- Left: Image -->
        <div class="qv-img-col">
          <div class="qv-img-wrap" id="qvImgWrap">
            <!-- Image injected by JS -->
          </div>
          <!-- Thumbnail strip (optional, populated by JS) -->
          <div class="qv-thumbs" id="qvThumbs"></div>
        </div>

        <!-- Right: Info -->
        <div class="qv-info-col">

          <p class="qv-eyebrow" id="qvType"></p>
          <h2 class="qv-title" id="qvTitle"></h2>

          <div class="qv-stars" id="qvStars" role="img" aria-label="5 star rating">
            {%- for i in (1..5) -%}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#f5a623" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </div>

          <div class="qv-price-row">
            <span class="qv-price" id="qvPrice"></span>
            <span class="qv-orig-price" id="qvOrigPrice"></span>
            <span class="qv-savings" id="qvSavings"></span>
          </div>

          <p class="qv-desc" id="qvDesc"></p>

          <!-- Variant selector (populated by JS) -->
          <div class="qv-variants" id="qvVariants"></div>

          <!-- Quantity -->
          <div class="qv-qty-row">
            <p class="qv-qty-label">QTY</p>
            <div class="qty-ctrl">
              <button class="qbtn" id="qvQtyMinus" aria-label="Decrease quantity">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <span class="qnum" id="qvQtyNum">1</span>
              <button class="qbtn" id="qvQtyPlus" aria-label="Increase quantity">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
            </div>
          </div>

          <!-- ATC -->
          <button class="btn-atc qv-atc" id="qvAtcBtn" style="margin:0;width:100%;padding:13px">
            ADD TO CART
          </button>

          <!-- View full product -->
          <a href="#" id="qvViewFull" class="qv-view-full">
            VIEW FULL PRODUCT DETAILS →
          </a>

          <!-- Trust mini-bar -->
          <div class="qv-trust">
            <span>✓ PCSIR Tested</span>
            <span>✓ DRAP Certified</span>
            <span>✓ Free Returns</span>
          </div>

        </div><!-- /qv-info-col -->
      </div><!-- /qv-grid -->
    </div><!-- /qv-content -->

  </div><!-- /qv-box -->
</div>
